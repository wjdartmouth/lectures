{
  "name": "final-review",
  "type": "module",
  "private": true,
  "scripts": {
    "dev":          "slidev --open",
    "dev:part2":    "slidev Year9_English_ReviewSessions_Slidev.md",
    "dev:handout":   "slidev Year9_English_ExamCheatsheet.md",
    "build:main":   "slidev build slides.md --base /lectures/ --out dist",
    "build:part2":  "slidev build Year9_English_ReviewSessions_Slidev.md --base /lectures/part2/ --out dist/part2",
    "build:handout": "slidev build Year9_English_ExamCheatsheet.md --base /lectures/handout/ --out dist/handout",
    "build:all":    "pnpm run build:main && pnpm run build:part2 && pnpm run build:handout && cp index.html dist/index.html",
    "deploy":       "pnpm run build:all && gh-pages -d dist",
    "export":       "slidev export"
  },
  "dependencies": {
    "@slidev/cli": "^52.15.2",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}